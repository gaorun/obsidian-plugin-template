{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2022",
		"strict": true,
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"noEmit": false,
		"outDir": "dist",
		"declaration": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"lib": ["ES2022"],
		"rootDir": "src"
	},
	"include": ["src/**/*.ts"]
}
